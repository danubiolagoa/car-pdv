{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as ui %}

{% block title %}Estoque - {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50" x-data="inventoryApp()">
    {{ ui.sidebar('inventory', user) }}

    <div class="lg:ml-64">
        {{ ui.header('Estoque') }}

        <main class="p-6 lg:p-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Movimentações Hoje</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1" x-text="stats.todayCount">0</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#EFF6FF] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Estoque Baixo</p>
                            <p class="text-2xl font-bold text-red-600 mt-1" x-text="lowStock.length">0</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#FEE2E2] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#EF4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Entradas (total)</p>
                            <p class="text-2xl font-bold text-green-600 mt-1" x-text="stats.totalIn.toFixed(2)">0</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#D1FAE5] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div x-show="lowStock.length > 0" class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-red-800 flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        Produtos com estoque baixo
                    </h3>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                    <template x-for="p in lowStock" :key="p.id">
                        <div class="bg-white border border-red-200 rounded-lg p-3 flex items-center justify-between">
                            <div>
                                <p class="font-medium text-gray-900 text-sm" x-text="p.name"></p>
                                <p class="text-xs text-gray-500" x-text="`SKU: ${p.sku}`"></p>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-red-600" x-text="`${p.current_stock} ${p.unit}`"></p>
                                <p class="text-xs text-gray-500" x-text="`mín: ${p.min_stock}`"></p>
                            </div>
                        </div>
                    </template>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                    <div class="flex flex-wrap gap-2">
                        <button @click="filterType = ''; loadMovements()" :class="filterType === '' ? 'bg-[#0C2340] text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-1.5 rounded-lg text-sm font-medium">Todas</button>
                        <button @click="filterType = 'in'; loadMovements()" :class="filterType === 'in' ? 'bg-green-600 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-1.5 rounded-lg text-sm font-medium">Entradas</button>
                        <button @click="filterType = 'out'; loadMovements()" :class="filterType === 'out' ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-1.5 rounded-lg text-sm font-medium">Saídas</button>
                        <button @click="filterType = 'adjustment'; loadMovements()" :class="filterType === 'adjustment' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'" class="px-3 py-1.5 rounded-lg text-sm font-medium">Ajustes</button>
                    </div>
                    <button @click="openModal()" class="w-full sm:w-auto px-4 py-2 bg-[#F59E0B] text-white rounded-lg hover:bg-[#D97706] transition-colors font-medium text-sm">+ Nova Movimentação</button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Data</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Tipo</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Produto</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Quantidade</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Estoque Anterior</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Estoque Atual</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Usuário</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Notas</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="m in movements" :key="m.id">
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="px-4 py-3 text-gray-500 text-xs" x-text="new Date(m.created_at).toLocaleString('pt-BR')"></td>
                                    <td class="px-4 py-3">
                                        <span :class="{
                                            'bg-green-100 text-green-700': m.type === 'in',
                                            'bg-red-100 text-red-700': m.type === 'out' || m.type === 'sale',
                                            'bg-blue-100 text-blue-700': m.type === 'adjustment',
                                            'bg-yellow-100 text-yellow-700': m.type === 'return',
                                        }" class="inline-block px-2 py-0.5 rounded text-xs font-medium" x-text="typeLabel(m.type)"></span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <p class="font-medium text-gray-900" x-text="m.product_name"></p>
                                        <p class="text-xs text-gray-500" x-text="m.sku"></p>
                                    </td>
                                    <td class="px-4 py-3 text-right font-medium" x-text="Number(m.quantity).toFixed(3)"></td>
                                    <td class="px-4 py-3 text-right text-gray-500" x-text="Number(m.previous_stock).toFixed(3)"></td>
                                    <td class="px-4 py-3 text-right font-semibold" x-text="Number(m.new_stock).toFixed(3)"></td>
                                    <td class="px-4 py-3 text-gray-700" x-text="m.user_name || '-'"></td>
                                    <td class="px-4 py-3 text-gray-500 text-xs" x-text="m.notes || '-'"></td>
                                </tr>
                            </template>
                            <tr x-show="!loading && movements.length === 0">
                                <td colspan="8" class="px-4 py-12 text-center text-gray-500">
                                    <p class="font-medium">Nenhuma movimentação encontrada</p>
                                </td>
                            </tr>
                            <tr x-show="loading">
                                <td colspan="8" class="px-4 py-8 text-center">
                                    <div class="inline-block animate-spin rounded-full h-6 w-6 border-2 border-[#F59E0B] border-t-transparent"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <div x-show="showModal" class="fixed inset-0 z-60 flex items-center justify-center bg-black/50" @click.self="closeModal()" style="display: none;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">Nova Movimentação</h3>
                <button @click="closeModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Produto *</label>
                    <select x-model="form.product_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                        <option value="">Selecione um produto</option>
                        <template x-for="p in products" :key="p.id">
                            <option :value="p.id" x-text="`${p.name} (${p.sku}) - Estoque: ${p.current_stock}`"></option>
                        </template>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tipo *</label>
                    <select x-model="form.type" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                        <option value="in">Entrada (compra)</option>
                        <option value="out">Saída (consumo interno)</option>
                        <option value="adjustment">Ajuste (inventário)</option>
                        <option value="return">Devolução</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Quantidade *</label>
                    <input type="number" step="0.001" x-model="form.quantity" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    <p class="text-xs text-gray-500 mt-1" x-show="form.type === 'adjustment'">Para ajuste, informe o estoque final desejado</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
                    <textarea x-model="form.notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 p-4 border-t border-gray-200 bg-gray-50 rounded-b-xl">
                <button @click="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancelar</button>
                <button @click="save()" :disabled="saving" class="px-4 py-2 text-sm font-medium text-white bg-[#F59E0B] rounded-lg hover:bg-[#D97706] disabled:opacity-50">
                    <span x-show="!saving">Registrar</span>
                    <span x-show="saving">Salvando...</span>
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function inventoryApp() {
    return {
        sidebarOpen: false,
        movements: [],
        lowStock: [],
        products: [],
        loading: true,
        saving: false,
        showModal: false,
        filterType: '',
        form: { product_id: '', type: 'in', quantity: 0, notes: '' },
        stats: { todayCount: 0, totalIn: 0 },

        async init() {
            await Promise.all([this.loadMovements(), this.loadLowStock(), this.loadProducts()]);
        },

        typeLabel(type) {
            return { in: 'Entrada', out: 'Saída', sale: 'Venda', adjustment: 'Ajuste', return: 'Devolução' }[type] || type;
        },

        async loadMovements() {
            this.loading = true;
            try {
                const params = new URLSearchParams();
                if (this.filterType) params.set('type', this.filterType);
                const res = await fetch(`/api/inventory/movements?${params}`);
                const data = await res.json();
                this.movements = data.movements || [];
                const today = new Date().toISOString().split('T')[0];
                this.stats.todayCount = this.movements.filter(m => m.created_at.startsWith(today)).length;
                this.stats.totalIn = this.movements
                    .filter(m => m.type === 'in')
                    .reduce((sum, m) => sum + Number(m.quantity), 0);
            } catch (e) {
                console.error(e);
            } finally {
                this.loading = false;
            }
        },

        async loadLowStock() {
            try {
                const res = await fetch('/api/inventory/low-stock');
                const data = await res.json();
                this.lowStock = data.products || [];
            } catch (e) {
                console.error(e);
            }
        },

        async loadProducts() {
            try {
                const res = await fetch('/api/products');
                const data = await res.json();
                this.products = data.products || [];
            } catch (e) {
                console.error(e);
            }
        },

        openModal() {
            this.form = { product_id: '', type: 'in', quantity: 0, notes: '' };
            this.showModal = true;
        },

        closeModal() { this.showModal = false; },

        async save() {
            this.saving = true;
            try {
                const res = await fetch('/api/inventory/movements', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form),
                });
                if (!res.ok) {
                    const err = await res.json();
                    alert(err.error || 'Erro ao registrar movimentação');
                    return;
                }
                this.closeModal();
                await Promise.all([this.loadMovements(), this.loadLowStock(), this.loadProducts()]);
            } catch (e) {
                alert('Erro de conexão');
            } finally {
                this.saving = false;
            }
        }
    };
}
</script>
{% endblock %}