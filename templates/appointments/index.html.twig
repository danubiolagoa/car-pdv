{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as ui %}

{% block title %}Agendamentos - {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50" x-data="appointmentsApp()">
    {{ ui.sidebar('appointments', user) }}

    <div class="lg:ml-64">
        {{ ui.header('Agendamentos de Serviços') }}

        <main class="p-6 lg:p-8">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                    <div class="flex items-center gap-3">
                        <label class="text-sm font-medium text-gray-700">Data:</label>
                        <input type="date" x-model="date" @change="loadAppointments()" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <button @click="openCreateModal()" class="w-full sm:w-auto px-4 py-2 bg-[#F59E0B] text-white rounded-lg hover:bg-[#D97706] transition-colors font-medium text-sm">+ Novo Agendamento</button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Horário</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Cliente</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Veículo</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Serviço</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Mecânico</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Valor</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500">Status</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="a in appointments" :key="a.id">
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="px-4 py-3 font-mono text-xs">
                                        <p x-text="formatTime(a.scheduled_at)"></p>
                                        <p class="text-gray-500" x-text="`até ${formatTime(a.estimated_end)}`"></p>
                                    </td>
                                    <td class="px-4 py-3">
                                        <p class="font-medium text-gray-900" x-text="a.customer_name"></p>
                                        <p class="text-xs text-gray-500" x-text="a.customer_phone || '-'"></p>
                                    </td>
                                    <td class="px-4 py-3 text-gray-700">
                                        <p x-show="a.plate" x-text="a.plate"></p>
                                        <p x-show="a.brand" class="text-xs text-gray-500" x-text="`${a.brand || ''} ${a.model || ''}`"></p>
                                    </td>
                                    <td class="px-4 py-3 text-gray-700" x-text="a.service_name || '-'"></td>
                                    <td class="px-4 py-3 text-gray-700" x-text="a.mechanic_name || '-'"></td>
                                    <td class="px-4 py-3 text-right font-medium" x-text="'R$ ' + Number(a.total_price || 0).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-center">
                                        <span :class="{
                                            'bg-blue-100 text-blue-700': a.status === 'scheduled',
                                            'bg-yellow-100 text-yellow-700': a.status === 'in_progress',
                                            'bg-green-100 text-green-700': a.status === 'completed',
                                            'bg-red-100 text-red-700': a.status === 'cancelled',
                                            'bg-gray-100 text-gray-500': a.status === 'no_show',
                                        }" class="inline-block px-2 py-0.5 rounded text-xs font-medium" x-text="statusLabel(a.status)"></span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <select @change="updateStatus(a.id, $event.target.value)" :value="a.status" class="text-xs border border-gray-300 rounded px-1 py-1">
                                            <option value="scheduled">Agendado</option>
                                            <option value="in_progress">Em andamento</option>
                                            <option value="completed">Concluído</option>
                                            <option value="cancelled">Cancelado</option>
                                            <option value="no_show">Não compareceu</option>
                                        </select>
                                    </td>
                                </tr>
                            </template>
                            <tr x-show="!loading && appointments.length === 0">
                                <td colspan="8" class="px-4 py-12 text-center text-gray-500">
                                    <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    </div>
                                    <p class="font-medium">Nenhum agendamento para esta data</p>
                                </td>
                            </tr>
                            <tr x-show="loading">
                                <td colspan="8" class="px-4 py-8 text-center">
                                    <div class="inline-block animate-spin rounded-full h-6 w-6 border-2 border-[#F59E0B] border-t-transparent"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <div x-show="showModal" class="fixed inset-0 z-60 flex items-center justify-center bg-black/50" @click.self="closeModal()" style="display: none;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">Novo Agendamento</h3>
                <button @click="closeModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cliente *</label>
                    <input type="text" x-model="customerSearch" @input.debounce.300ms="searchCustomers()" placeholder="Buscar cliente..." class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    <div x-show="customerResults.length > 0" class="mt-2 border border-gray-200 rounded-lg max-h-40 overflow-y-auto">
                        <template x-for="c in customerResults" :key="c.id">
                            <button @click="selectCustomer(c)" class="w-full px-3 py-2 hover:bg-gray-50 text-left text-sm border-b border-gray-100 last:border-b-0">
                                <p class="font-medium" x-text="c.name"></p>
                                <p class="text-xs text-gray-500" x-text="c.cpf_cnpj || '-'"></p>
                            </button>
                        </template>
                    </div>
                    <div x-show="selectedCustomer" class="mt-2 p-2 bg-blue-50 border border-blue-200 rounded text-sm">
                        Selecionado: <strong x-text="selectedCustomer?.name"></strong>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Serviço</label>
                    <select x-model="form.service_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                        <option value="">Selecione um serviço</option>
                        <template x-for="s in services" :key="s.id">
                            <option :value="s.id" x-text="`${s.name} - R$ ${Number(s.price).toFixed(2)} (${s.duration_minutes}min)`"></option>
                        </template>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mecânico</label>
                    <select x-model="form.mechanic_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                        <option value="">Sem mecânico definido</option>
                        <template x-for="m in mechanics" :key="m.id">
                            <option :value="m.id" x-text="m.name"></option>
                        </template>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Data e Hora *</label>
                    <input type="datetime-local" x-model="form.scheduled_at" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
                    <textarea x-model="form.notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 p-4 border-t border-gray-200 bg-gray-50 rounded-b-xl">
                <button @click="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancelar</button>
                <button @click="save()" :disabled="saving" class="px-4 py-2 text-sm font-medium text-white bg-[#F59E0B] rounded-lg hover:bg-[#D97706] disabled:opacity-50">
                    <span x-show="!saving">Agendar</span>
                    <span x-show="saving">Salvando...</span>
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function appointmentsApp() {
    return {
        sidebarOpen: false,
        appointments: [],
        services: [],
        mechanics: [],
        loading: true,
        saving: false,
        showModal: false,
        date: new Date().toISOString().split('T')[0],
        customerSearch: '',
        customerResults: [],
        selectedCustomer: null,
        form: { service_id: '', mechanic_id: '', scheduled_at: '', notes: '' },

        async init() {
            await Promise.all([this.loadAppointments(), this.loadServices(), this.loadMechanics()]);
        },

        statusLabel(s) {
            return { scheduled: 'Agendado', in_progress: 'Em andamento', completed: 'Concluído', cancelled: 'Cancelado', no_show: 'Não compareceu' }[s] || s;
        },

        formatTime(iso) {
            if (!iso) return '-';
            return new Date(iso).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        },

        async loadAppointments() {
            this.loading = true;
            try {
                const res = await fetch(`/api/appointments?date=${this.date}`);
                const data = await res.json();
                this.appointments = data.appointments || [];
            } catch (e) {
                console.error(e);
            } finally {
                this.loading = false;
            }
        },

        async loadServices() {
            try {
                const res = await fetch('/api/services');
                const data = await res.json();
                this.services = data.services || [];
            } catch (e) { console.error(e); }
        },

        async loadMechanics() {
            try {
                const res = await fetch('/api/mechanics');
                const data = await res.json();
                this.mechanics = data.mechanics || [];
            } catch (e) { console.error(e); }
        },

        async searchCustomers() {
            if (!this.customerSearch) { this.customerResults = []; return; }
            try {
                const res = await fetch(`/api/customers?search=${encodeURIComponent(this.customerSearch)}`);
                const data = await res.json();
                this.customerResults = (data.customers || []).slice(0, 6);
            } catch (e) { console.error(e); }
        },

        selectCustomer(c) {
            this.selectedCustomer = c;
            this.customerSearch = '';
            this.customerResults = [];
        },

        openCreateModal() {
            this.form = { service_id: '', mechanic_id: '', scheduled_at: `${this.date}T09:00`, notes: '' };
            this.selectedCustomer = null;
            this.customerSearch = '';
            this.showModal = true;
        },

        closeModal() { this.showModal = false; },

        async save() {
            if (!this.selectedCustomer) { alert('Selecione um cliente'); return; }
            if (!this.form.scheduled_at) { alert('Informe data e hora'); return; }
            this.saving = true;
            try {
                const payload = {
                    customer_id: this.selectedCustomer.id,
                    service_id: this.form.service_id || null,
                    mechanic_id: this.form.mechanic_id || null,
                    scheduled_at: this.form.scheduled_at.replace('T', ' ') + ':00',
                    notes: this.form.notes,
                };
                const res = await fetch('/api/appointments', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                });
                if (!res.ok) {
                    const err = await res.json();
                    alert(err.error || 'Erro ao agendar');
                    return;
                }
                this.closeModal();
                await this.loadAppointments();
            } catch (e) {
                alert('Erro de conexão');
            } finally {
                this.saving = false;
            }
        },

        async updateStatus(id, status) {
            if (!status) return;
            try {
                const res = await fetch(`/api/appointments/${id}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status }),
                });
                if (!res.ok) { alert('Erro ao atualizar status'); await this.loadAppointments(); return; }
                await this.loadAppointments();
            } catch (e) {
                alert('Erro de conexão');
            }
        }
    };
}
</script>
{% endblock %}