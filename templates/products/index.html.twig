{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as ui %}

{% block title %}Produtos - {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50" x-data="productsApp()">
    {{ ui.sidebar('products', user) }}

    <div class="lg:ml-64">
        {{ ui.header('Produtos') }}

        <main class="p-6 lg:p-8">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                    <div class="flex gap-2 w-full sm:w-auto">
                        <input type="text" x-model="search" @input.debounce="loadProducts()" placeholder="Buscar produto, SKU ou código..." class="w-full sm:w-72 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                        <button @click="loadProducts()" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </button>
                    </div>
                    <button @click="openCreateModal()" class="w-full sm:w-auto px-4 py-2 bg-[#F59E0B] text-white rounded-lg hover:bg-[#D97706] transition-colors font-medium text-sm">
                        + Novo Produto
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="text-left px-4 py-3 font-medium text-gray-500">SKU</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Nome</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Categoria</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Preço Venda</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Preço Custo</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Estoque</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500">Ativo</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="p in products" :key="p.id">
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="px-4 py-3 font-mono text-xs text-gray-500" x-text="p.sku"></td>
                                    <td class="px-4 py-3 font-medium text-gray-900" x-text="p.name"></td>
                                    <td class="px-4 py-3 text-gray-500" x-text="p.category_name || '-'"></td>
                                    <td class="px-4 py-3 text-right font-medium" x-text="'R$ ' + Number(p.sale_price).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-right text-gray-500" x-text="'R$ ' + Number(p.cost_price).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-right">
                                        <span :class="Number(p.current_stock) <= Number(p.min_stock) ? 'text-red-600 font-semibold' : 'text-gray-700'" x-text="Number(p.current_stock).toFixed(3)"></span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span :class="p.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'" class="inline-block px-2 py-0.5 rounded-full text-xs font-medium" x-text="p.is_active ? 'Sim' : 'Não'"></span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <button @click="openEditModal(p)" class="text-[#2563EB] hover:text-[#1D4ED8] mr-2" title="Editar">
                                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </button>
                                        <button @click="deleteProduct(p.id, p.name)" class="text-red-500 hover:text-red-700" title="Desativar">
                                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            </template>
                            <tr x-show="!loading && products.length === 0">
                                <td colspan="8" class="px-4 py-12 text-center text-gray-500">
                                    <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
                                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                                    </div>
                                    <p class="font-medium">Nenhum produto encontrado</p>
                                    <p class="text-sm mt-1">Clique em "+ Novo Produto" para cadastrar.</p>
                                </td>
                            </tr>
                            <tr x-show="loading">
                                <td colspan="8" class="px-4 py-8 text-center text-gray-500">
                                    <div class="inline-block animate-spin rounded-full h-6 w-6 border-2 border-[#F59E0B] border-t-transparent"></div>
                                    <p class="mt-2 text-sm">Carregando...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Create/Edit Modal -->
    <div x-show="showModal" class="fixed inset-0 z-60 flex items-center justify-center bg-black/50" @click.self="closeModal()" style="display: none;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900" x-text="editingId ? 'Editar Produto' : 'Novo Produto'"></h3>
                <button @click="closeModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-4 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">SKU *</label>
                        <input type="text" x-model="form.sku" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Código de Barras</label>
                        <input type="text" x-model="form.barcode" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nome *</label>
                    <input type="text" x-model="form.name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
                    <textarea x-model="form.description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Categoria</label>
                        <select x-model="form.category_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                            <option value="">Sem categoria</option>
                            <template x-for="cat in categories" :key="cat.id">
                                <option :value="cat.id" x-text="cat.name"></option>
                            </template>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Unidade</label>
                        <select x-model="form.unit" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                            <option value="UN">Unidade</option>
                            <option value="KG">Quilograma</option>
                            <option value="LT">Litro</option>
                            <option value="MT">Metro</option>
                            <option value="CX">Caixa</option>
                            <option value="PC">Peça</option>
                            <option value="SVC">Serviço</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Preço de Custo</label>
                        <input type="number" step="0.01" x-model="form.cost_price" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Preço de Venda *</label>
                        <input type="number" step="0.01" x-model="form.sale_price" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estoque Atual</label>
                        <input type="number" step="0.001" x-model="form.current_stock" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estoque Mínimo</label>
                        <input type="number" step="0.001" x-model="form.min_stock" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Localização</label>
                    <input type="text" x-model="form.location" placeholder="Ex: Prateleira A3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
            </div>
            <div class="flex justify-end gap-3 p-4 border-t border-gray-200 bg-gray-50 rounded-b-xl">
                <button @click="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancelar</button>
                <button @click="saveProduct()" :disabled="saving" class="px-4 py-2 text-sm font-medium text-white bg-[#F59E0B] rounded-lg hover:bg-[#D97706] transition-colors disabled:opacity-50">
                    <span x-show="!saving" x-text="editingId ? 'Atualizar' : 'Salvar'"></span>
                    <span x-show="saving">Salvando...</span>
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function productsApp() {
    return {
        sidebarOpen: false,
        products: [],
        categories: [],
        search: '',
        loading: true,
        saving: false,
        showModal: false,
        editingId: null,
        form: {
            sku: '',
            barcode: '',
            name: '',
            description: '',
            category_id: '',
            unit: 'UN',
            cost_price: 0,
            sale_price: 0,
            current_stock: 0,
            min_stock: 0,
            location: '',
        },

        async init() {
            await Promise.all([this.loadProducts(), this.loadCategories()]);
        },

        async loadProducts() {
            this.loading = true;
            try {
                const params = new URLSearchParams();
                if (this.search) params.set('search', this.search);
                const res = await fetch(`/api/products?${params}`);
                const data = await res.json();
                this.products = data.products || [];
            } catch (e) {
                console.error('Erro ao carregar produtos:', e);
            } finally {
                this.loading = false;
            }
        },

        async loadCategories() {
            try {
                const res = await fetch('/api/categories');
                const data = await res.json();
                this.categories = data.categories || [];
            } catch (e) {
                console.error('Erro ao carregar categorias:', e);
            }
        },

        openCreateModal() {
            this.editingId = null;
            this.form = { sku: '', barcode: '', name: '', description: '', category_id: '', unit: 'UN', cost_price: 0, sale_price: 0, current_stock: 0, min_stock: 0, location: '' };
            this.showModal = true;
        },

        openEditModal(product) {
            this.editingId = product.id;
            this.form = {
                sku: product.sku || '',
                barcode: product.barcode || '',
                name: product.name || '',
                description: '',
                category_id: product.category_id || '',
                unit: product.unit || 'UN',
                cost_price: product.cost_price || 0,
                sale_price: product.sale_price || 0,
                current_stock: product.current_stock || 0,
                min_stock: product.min_stock || 0,
                location: product.location || '',
            };
            this.showModal = true;
        },

        closeModal() {
            this.showModal = false;
            this.editingId = null;
        },

        async saveProduct() {
            this.saving = true;
            try {
                const url = this.editingId ? `/api/products/${this.editingId}` : '/api/products';
                const method = this.editingId ? 'PUT' : 'POST';
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form),
                });
                if (!res.ok) {
                    const err = await res.json();
                    alert(err.error || 'Erro ao salvar produto');
                    return;
                }
                this.closeModal();
                await this.loadProducts();
            } catch (e) {
                alert('Erro de conexão ao salvar produto');
            } finally {
                this.saving = false;
            }
        },

        async deleteProduct(id, name) {
            if (!confirm(`Desativar o produto "${name}"?`)) return;
            try {
                const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
                if (!res.ok) {
                    alert('Erro ao desativar produto');
                    return;
                }
                await this.loadProducts();
            } catch (e) {
                alert('Erro de conexão');
            }
        }
    };
}
</script>
{% endblock %}
