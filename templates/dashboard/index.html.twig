{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as ui %}

{% block title %}Dashboard - {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50" x-data="{ sidebarOpen: false }">
    {{ ui.sidebar('dashboard', user) }}

    <div class="lg:ml-64">
        {{ ui.header('Dashboard') }}

        <!-- Content -->
        <main class="p-6 lg:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Vendas Hoje</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1">R$ {{ '%.2f'|format(kpi.sales_today) }}</p>
                            <p class="text-xs text-gray-400 mt-1">{{ kpi.sales_today_count }} pedido{{ kpi.sales_today_count != 1 ? 's' }}</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#EFF6FF] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Vendas Abertas</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1">{{ kpi.pending_sales }}</p>
                            <p class="text-xs text-gray-400 mt-1">aguardando finalização</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#FEF3C7] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#F59E0B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Estoque Baixo</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1">{{ kpi.low_stock }}</p>
                            <p class="text-xs text-gray-400 mt-1">produtos abaixo do mínimo</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#FEE2E2] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#EF4444]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-gray-500">Agendamentos Hoje</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1">{{ kpi.appointments_today }}</p>
                            <p class="text-xs text-gray-400 mt-1">{{ kpi.appointments_pending }} pendentes</p>
                        </div>
                        <div class="w-10 h-10 rounded-lg bg-[#D1FAE5] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[#10B981]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Vendas do Dia</h3>
                    <div x-data="{ loading: true, sales: [] }" x-init="
                        fetch('/api/sales?limit=5')
                            .then(r => r.json())
                            .then(d => { sales = d.data || d.sales || []; loading = false; })
                            .catch(() => loading = false)
                    ">
                        <template x-if="loading">
                            <p class="text-gray-400 text-sm">Carregando...</p>
                        </template>
                        <template x-if="!loading && sales.length === 0">
                            <p class="text-gray-400 text-sm">Nenhuma venda hoje</p>
                        </template>
                        <template x-for="sale in sales" :key="sale.id">
                            <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                                <div>
                                    <p class="text-sm font-medium text-gray-900" x-text="sale.sale_number"></p>
                                    <p class="text-xs text-gray-400" x-text="sale.total ? 'R$ ' + parseFloat(sale.total).toFixed(2) : ''"></p>
                                </div>
                                <span class="text-xs px-2 py-1 rounded-full" :class="{
                                    'bg-green-100 text-green-700': sale.status === 'completed',
                                    'bg-yellow-100 text-yellow-700': sale.status === 'open',
                                    'bg-red-100 text-red-700': sale.status === 'cancelled'
                                }" x-text="sale.status"></span>
                            </div>
                        </template>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Acesso Rápido</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <a href="/app/pdv" class="p-4 bg-[#EFF6FF] rounded-xl hover:bg-blue-100 transition-colors text-center">
                            <p class="text-sm font-medium text-[#2563EB]">Nova Venda</p>
                        </a>
                        <a href="/app/products" class="p-4 bg-[#FEF3C7] rounded-xl hover:bg-yellow-100 transition-colors text-center">
                            <p class="text-sm font-medium text-[#F59E0B]">Produtos</p>
                        </a>
                        <a href="/app/customers" class="p-4 bg-[#D1FAE5] rounded-xl hover:bg-green-100 transition-colors text-center">
                            <p class="text-sm font-medium text-[#10B981]">Clientes</p>
                        </a>
                        <a href="/app/appointments" class="p-4 bg-[#FEE2E2] rounded-xl hover:bg-red-100 transition-colors text-center">
                            <p class="text-sm font-medium text-[#EF4444]">Agendamentos</p>
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
