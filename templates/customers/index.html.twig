{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as ui %}

{% block title %}Clientes - {{ app_name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50" x-data="customersApp()">
    {{ ui.sidebar('customers', user) }}

    <div class="lg:ml-64">
        {{ ui.header('Clientes & Veículos') }}

        <main class="p-6 lg:p-8">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200">
                <div class="p-4 border-b border-gray-200 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                    <input type="text" x-model="search" @input.debounce.300ms="loadCustomers()" placeholder="Buscar por nome, CPF/CNPJ, e-mail ou telefone..." class="w-full sm:w-96 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    <button @click="openCreateModal()" class="w-full sm:w-auto px-4 py-2 bg-[#F59E0B] text-white rounded-lg hover:bg-[#D97706] transition-colors font-medium text-sm">+ Novo Cliente</button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Nome</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">CPF/CNPJ</th>
                                <th class="text-left px-4 py-3 font-medium text-gray-500">Contato</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500">Veículos</th>
                                <th class="text-right px-4 py-3 font-medium text-gray-500">Total Compras</th>
                                <th class="text-center px-4 py-3 font-medium text-gray-500 w-32">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="c in customers" :key="c.id">
                                <tr class="border-b border-gray-100 hover:bg-gray-50">
                                    <td class="px-4 py-3">
                                        <p class="font-medium text-gray-900" x-text="c.name"></p>
                                    </td>
                                    <td class="px-4 py-3 text-gray-500 font-mono text-xs" x-text="formatDoc(c.cpf_cnpj)"></td>
                                    <td class="px-4 py-3 text-gray-500">
                                        <p x-show="c.email" x-text="c.email"></p>
                                        <p x-show="c.phone" x-text="c.phone"></p>
                                        <p x-show="c.mobile" class="text-xs" x-text="`Cel: ${c.mobile}`"></p>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700" x-text="c.vehicles_count"></span>
                                    </td>
                                    <td class="px-4 py-3 text-right font-medium" x-text="'R$ ' + Number(c.total_purchases || 0).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-center">
                                        <button @click="openEditModal(c)" class="text-[#2563EB] hover:text-[#1D4ED8] mr-2" title="Editar">
                                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                        </button>
                                        <button @click="openVehicleModal(c)" class="text-green-600 hover:text-green-700 mr-2" title="Adicionar veículo">
                                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path></svg>
                                        </button>
                                        <button @click="deleteCustomer(c.id, c.name)" class="text-red-500 hover:text-red-700" title="Desativar">
                                            <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                            </template>
                            <tr x-show="!loading && customers.length === 0">
                                <td colspan="6" class="px-4 py-12 text-center text-gray-500">
                                    <p class="font-medium">Nenhum cliente cadastrado</p>
                                </td>
                            </tr>
                            <tr x-show="loading">
                                <td colspan="6" class="px-4 py-8 text-center">
                                    <div class="inline-block animate-spin rounded-full h-6 w-6 border-2 border-[#F59E0B] border-t-transparent"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- Customer Modal -->
    <div x-show="showCustomerModal" class="fixed inset-0 z-60 flex items-center justify-center bg-black/50" @click.self="closeCustomerModal()" style="display: none;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900" x-text="editingId ? 'Editar Cliente' : 'Novo Cliente'"></h3>
                <button @click="closeCustomerModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nome *</label>
                    <input type="text" x-model="form.name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">CPF/CNPJ</label>
                    <input type="text" x-model="form.cpf_cnpj" @input="maskDoc($event)" placeholder="000.000.000-00" maxlength="18" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
                        <input type="email" x-model="form.email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Telefone</label>
                        <input type="text" x-model="form.phone" @input="maskPhone($event)" placeholder="(00) 0000-0000" maxlength="14" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Celular</label>
                    <input type="text" x-model="form.mobile" @input="maskPhone($event)" placeholder="(00) 00000-0000" maxlength="15" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Observações</label>
                    <textarea x-model="form.notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 p-4 border-t border-gray-200 bg-gray-50 rounded-b-xl">
                <button @click="closeCustomerModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancelar</button>
                <button @click="saveCustomer()" :disabled="saving" class="px-4 py-2 text-sm font-medium text-white bg-[#F59E0B] rounded-lg hover:bg-[#D97706] disabled:opacity-50">
                    <span x-show="!saving" x-text="editingId ? 'Atualizar' : 'Salvar'"></span>
                    <span x-show="saving">Salvando...</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Vehicle Modal -->
    <div x-show="showVehicleModal" class="fixed inset-0 z-60 flex items-center justify-center bg-black/50" @click.self="closeVehicleModal()" style="display: none;">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900">Adicionar Veículo</h3>
                <button @click="closeVehicleModal()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="p-4 space-y-4">
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-sm text-blue-800">
                    Cliente: <strong x-text="vehicleCustomer?.name"></strong>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Placa *</label>
                        <input type="text" x-model="vehicleForm.plate" @input="vehicleForm.plate = $event.target.value.toUpperCase()" placeholder="ABC-1D23" maxlength="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent uppercase">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ano</label>
                        <input type="number" x-model="vehicleForm.year" placeholder="2020" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Marca</label>
                        <input type="text" x-model="vehicleForm.brand" placeholder="Toyota" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Modelo</label>
                        <input type="text" x-model="vehicleForm.model" placeholder="Corolla" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cor</label>
                    <input type="text" x-model="vehicleForm.color" placeholder="Prata" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-[#F59E0B] focus:border-transparent">
                </div>
            </div>
            <div class="flex justify-end gap-3 p-4 border-t border-gray-200 bg-gray-50 rounded-b-xl">
                <button @click="closeVehicleModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancelar</button>
                <button @click="saveVehicle()" :disabled="saving" class="px-4 py-2 text-sm font-medium text-white bg-[#F59E0B] rounded-lg hover:bg-[#D97706] disabled:opacity-50">
                    <span x-show="!saving">Salvar</span>
                    <span x-show="saving">Salvando...</span>
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function customersApp() {
    return {
        sidebarOpen: false,
        customers: [],
        loading: true,
        saving: false,
        showCustomerModal: false,
        showVehicleModal: false,
        editingId: null,
        vehicleCustomer: null,
        search: '',
        form: { name: '', cpf_cnpj: '', email: '', phone: '', mobile: '', notes: '' },
        vehicleForm: { plate: '', brand: '', model: '', year: null, color: '' },

        async init() {
            await this.loadCustomers();
        },

        formatDoc(doc) {
            if (!doc) return '-';
            doc = doc.replace(/\D/g, '');
            if (doc.length === 11) return doc.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
            if (doc.length === 14) return doc.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5');
            return doc;
        },

        maskDoc(e) {
            let v = e.target.value.replace(/\D/g, '');
            if (v.length <= 11) {
                v = v.replace(/(\d{3})(\d)/, '$1.$2').replace(/(\d{3})(\d)/, '$1.$2').replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            } else {
                v = v.replace(/^(\d{2})(\d)/, '$1.$2').replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3').replace(/\.(\d{3})(\d)/, '.$1/$2').replace(/(\d{4})(\d)/, '$1-$2');
            }
            e.target.value = v.slice(0, 18);
            this.form.cpf_cnpj = e.target.value;
        },

        maskPhone(e) {
            let v = e.target.value.replace(/\D/g, '');
            if (v.length <= 10) {
                v = v.replace(/(\d{2})(\d)/, '($1) $2').replace(/(\d{4})(\d)/, '$1-$2');
            } else {
                v = v.replace(/(\d{2})(\d)/, '($1) $2').replace(/(\d{5})(\d)/, '$1-$2');
            }
            e.target.value = v.slice(0, 15);
        },

        async loadCustomers() {
            this.loading = true;
            try {
                const params = new URLSearchParams();
                if (this.search) params.set('search', this.search);
                const res = await fetch(`/api/customers?${params}`);
                const data = await res.json();
                this.customers = data.customers || [];
            } catch (e) {
                console.error(e);
            } finally {
                this.loading = false;
            }
        },

        openCreateModal() {
            this.editingId = null;
            this.form = { name: '', cpf_cnpj: '', email: '', phone: '', mobile: '', notes: '' };
            this.showCustomerModal = true;
        },

        openEditModal(c) {
            this.editingId = c.id;
            this.form = { name: c.name, cpf_cnpj: c.cpf_cnpj || '', email: c.email || '', phone: c.phone || '', mobile: c.mobile || '', notes: '' };
            this.showCustomerModal = true;
        },

        closeCustomerModal() { this.showCustomerModal = false; this.editingId = null; },

        async saveCustomer() {
            this.saving = true;
            try {
                const url = this.editingId ? `/api/customers/${this.editingId}` : '/api/customers';
                const method = this.editingId ? 'PUT' : 'POST';
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form),
                });
                if (!res.ok) {
                    const err = await res.json();
                    alert(err.error || 'Erro ao salvar');
                    return;
                }
                this.closeCustomerModal();
                await this.loadCustomers();
            } catch (e) {
                alert('Erro de conexão');
            } finally {
                this.saving = false;
            }
        },

        async deleteCustomer(id, name) {
            if (!confirm(`Desativar o cliente "${name}"?`)) return;
            try {
                const res = await fetch(`/api/customers/${id}`, { method: 'DELETE' });
                if (!res.ok) { alert('Erro'); return; }
                await this.loadCustomers();
            } catch (e) {
                alert('Erro de conexão');
            }
        },

        openVehicleModal(c) {
            this.vehicleCustomer = c;
            this.vehicleForm = { plate: '', brand: '', model: '', year: null, color: '' };
            this.showVehicleModal = true;
        },

        closeVehicleModal() { this.showVehicleModal = false; this.vehicleCustomer = null; },

        async saveVehicle() {
            this.saving = true;
            try {
                const res = await fetch('/api/vehicles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...this.vehicleForm, customer_id: this.vehicleCustomer.id }),
                });
                if (!res.ok) {
                    const err = await res.json();
                    alert(err.error || 'Erro ao salvar veículo');
                    return;
                }
                this.closeVehicleModal();
                await this.loadCustomers();
            } catch (e) {
                alert('Erro de conexão');
            } finally {
                this.saving = false;
            }
        }
    };
}
</script>
{% endblock %}