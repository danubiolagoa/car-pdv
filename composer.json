{
    "name": "danubiolagoa/car-pdv",
    "description": "Sistema PDV para oficinas mecânicas e lojas de acessórios automotivos",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Danubio Lagoa",
            "email": "danubiolagoa@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "doctrine/orm": "^3.2",
        "doctrine/dbal": "^4.1",
        "doctrine/migrations": "^3.8",
        "firebase/php-jwt": "^6.10",
        "vlucas/valitron": "^1.4",
        "monolog/monolog": "^3.7",
        "php-di/slim-bridge": "^3.4",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "vlucas/phpdotenv": "^5.6",
        "twig/twig": "^3.14",
        "symfony/cache": "^7.0",
        "symfony/var-exporter": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Migrations\\": "database/migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "vendor/bin/doctrine-migrations migrate",
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse src/ --level=6"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "policy": {
            "advisories": {
                "ignore": ["PKSA-y2cr-5h3j-g3ys"]
            }
        }
    }
}