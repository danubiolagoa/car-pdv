APP_ENV=development
APP_NAME=CAR-PDV
APP_URL=http://localhost:8080

# Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:password@host-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_ISSUER=car-pdv
JWT_AUDIENCE=car-pdv
JWT_EXPIRATION=86400

# Admin default
ADMIN_EMAIL=admin@car-pdv.local
ADMIN_PASSWORD=admin123

# Vercel
VERCEL_TOKEN=
VERCEL_ORG=
VERCEL_PROJECT=